// storage.rules
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Organization profile images — public read, owner-only write
    match /organizations/{orgId}/profile.jpg {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == orgId;
    }

    // Vendor verification documents — vendor can upload their own,
    // any signed-in user can read (download URLs are token-gated anyway)
    match /vendors/{vendorId}/documents/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == vendorId;
    }

    // Proof-of-action photos (donor "Donate", vendor "Mark Ready for Pickup",
    // org "Mark Picked Up" / "Complete") — any signed-in user can read since
    // donor, org, and vendor on the same record all need to view each
    // other's proof. Write is open to any signed-in user; the app layer
    // (Firestore security rules + UI) already restricts which role can
    // trigger which action on a given record, so this only needs to keep
    // signed-out access out.
    match /proofs/{recordId}/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
